# -------------------------------------------------------
# LeetCode Credentials
# Get these from your browser DevTools while on leetcode.com
# Application tab → Cookies → leetcode.com
# -------------------------------------------------------

LEETCODE_SESSION=your_leetcode_session_cookie_here
LEETCODE_CSRF_TOKEN=your_csrftoken_cookie_here
LEETCODE_USERNAME=your_leetcode_username_here

# -------------------------------------------------------
# GitHub Credentials
# Create at: https://github.com/settings/tokens
# Required scope: repo (full control of private repositories)
# -------------------------------------------------------

GITHUB_TOKEN=your_github_personal_access_token_here

# -------------------------------------------------------
# GitHub Repo Settings
# Format: "username/repo-name"  (example: rajpatel637/leetcode-solutions)
# -------------------------------------------------------

GITHUB_REPO=username/repo-name
GITHUB_BRANCH=main

# -------------------------------------------------------
# Sync Settings
# -------------------------------------------------------

# Delay in seconds between API requests (do not set below 0.3)
REQUEST_DELAY=0.5

# Maximum submissions to fetch per run (set to 0 for unlimited)
MAX_SUBMISSIONS=0
