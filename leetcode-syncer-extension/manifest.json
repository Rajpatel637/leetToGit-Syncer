{
  "manifest_version": 3,
  "name": "LeetCode → GitHub Syncer",
  "short_name": "LC→GH Syncer",
  "version": "1.0.0",
  "description": "Instantly syncs your Accepted LeetCode solutions to a GitHub repository the moment you solve a problem. Zero configuration, fully automatic.",
  "homepage_url": "https://github.com/Rajpatel637/leetToGit",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetCode → GitHub Syncer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "cookies",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://leetcode.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["welcome.html", "privacy_policy.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self' https://api.github.com https://leetcode.com"
  }
}